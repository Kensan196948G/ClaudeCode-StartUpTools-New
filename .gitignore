# ============================================================
# Claude-EdgeChromeDevTools .gitignore
# ============================================================

# Git Worktrees（isolated workspace directories）
.worktrees/

# 機密情報（絶対にコミットしない）
config/config.json
config/config.local.json
config/managed-agents.json
*.key
*.pem
id_rsa*
id_ed25519*
*.secret

# 環境固有の設定（オプション - コミットするかはチーム判断）
# config/config.json の githubToken, braveApiKey がコミットされるのを防ぐ場合:
# config/config.json

# Windows 一時ファイル
Thumbs.db
desktop.ini
*.lnk

# PowerShell
*.ps1~
*.psm1~

# ブラウザプロファイル（大容量・不要）
C:/DevTools-*
DevTools-edge-*
DevTools-chrome-*

# SSH 一時ファイル
*.ssh/known_hosts.old
*.ssh/config.bak

# Claude Code ローカルファイル
.claude/logs/
.claude/memory/project-context.json
.claude/settings.local.json
.claude/scheduled_tasks.lock

# hookify ローカルルール（ユーザー固有・コミット不要）
# 推奨ルール集は docs/common/17_hookify-CTO-guard.md を参照
# NOTE: hookify プラグインの命名規約は .claude/hookify.{name}.local.md
#       のフラット配置のみ想定。サブフォルダ配置が必要になったら **/ 付きへ拡張。
.claude/hookify.*.local.md
.mcp.json.bak.*
.mcp.json.backup.*

# ClaudeOS ランタイム状態（セッション固有・コミット不要）
state.json

# テンプレート編集用バックアップ（作業中の退避先・コミット不要）
Claude/templates/claude/START_PROMPT-backup/

# Claude CLI ツール設定（API キーを含む可能性）
Claude/settings.json
Claude/settings.local.json

# config.json バックアップ（機密情報含む可能性があるため除外）
config/backups/*.json

# バックアップファイル
*.bak
*.backup
*~

# ログファイル
*.log
*.jsonl

# OS 固有
.DS_Store
*.swp
*.swo

# IDE
.vscode/
.idea/
*.code-workspace

# Node.js (MCP 関連)
node_modules/
package-lock.json
npm-debug.log*

# Python
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/

# テスト出力
test-results/
coverage/
*.test.log

# Playwright MCP テスト成果物（再生成可能・コミット不要）
.playwright-mcp/
playwright-test*.png

# 一時ファイル
tmp/
temp/
*.tmp

# 環境変数未展開による誤作成ディレクトリ
%USERPROFILE%/
%TEMP%/

# tmux 関連
logs/tmux-monitor-*.log

# 重複ディレクトリ
config/config/
*.backup-pre-puppeteer
testResults.xml

# reports/ — ClaudeOS ループ生成レポート（README.md のみ追跡）
reports/.loop-*.md
reports/*.log
reports/*.xml
reports/agent-transcripts/
reports/dashboards/
reports/lint-summary.json
reports/coverage-summary.json
reports/deploy-runbook.md
reports/audit/
reports/cmdb/
reports/deploy-runbook-*.md
reports/ultrareview/

# バックアップディレクトリ
scripts/claudeos-back/

# Codex 個人設定（共有テンプレートは .codex/config.toml.example を参照）
.codex/config.toml

# 認証・資格情報（絶対にコミットしない）
.credentials.json
**/credentials.json
**/.credentials.json

# Sample ディレクトリ（ローカル作業コピー・2GB超のため全除外）
# テンプレートは Claude/templates/ に集約済み
Sample/

# バックアッププロンプト
Claude/templates/claude/START_PROMPT-backup*.md

# claude-mem MCP が自動生成するコンテキストファイル（コミット不要・各ディレクトリに散在）
# NOTE: CLAUDE.md at repo root and Claude/templates/ are intentional — only sub-directory auto-generated ones
.github/issues/CLAUDE.md
.github/workflows/CLAUDE.md
.claude/claudeos/system/CLAUDE.md
scripts/lib/CLAUDE.md
scripts/main/CLAUDE.md
tests/CLAUDE.md
Claude/templates/claude/instructions/CLAUDE.md
.claude/claudeos/commands/CLAUDE.md
docs/common/CLAUDE.md
.github/CLAUDE.md
docs/CLAUDE.md
Claude/templates/claude/Claude/
