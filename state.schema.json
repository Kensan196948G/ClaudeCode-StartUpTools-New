{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Kensan196948G/ClaudeCode-StartUpTools-New/main/state.schema.json",
  "title": "ClaudeOS v8 state.json",
  "description": "Runtime state for ClaudeOS autonomous development loops. Read by session-start.js / pre-compact.js / notify-stable.js hooks. Validates: goal / kpi / execution / stable / token / effort_strategy / compact / notification / task_budget / cache / session / codex / frontier / message_bus / learning / debug / onboarding / improvement / automation.",
  "type": "object",
  "required": [
    "goal",
    "kpi",
    "execution",
    "stable",
    "token",
    "effort_strategy",
    "compact",
    "notification"
  ],
  "properties": {
    "goal": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" }
      }
    },
    "project": {
      "type": "object",
      "description": "Project timeline constraints. Release timing is determined by CTO judgment (deploy.ready=true). 6 months is a default guideline only, not a hard constraint.",
      "properties": {
        "registration_date": { "type": ["string", "null"], "format": "date" },
        "release_deadline": { "type": ["string", "null"], "format": "date" },
        "release_deadline_note": { "type": "string" },
        "duration_months": { "type": ["integer", "null"], "minimum": 1, "description": "開発期間の目安（月）。CTO判断で無期限の場合は null を設定可" },
        "cron_enabled": { "type": "boolean" },
        "session_max_minutes": { "type": "integer", "minimum": 1, "maximum": 300 },
        "phase_mode": { "type": "string", "enum": ["development", "maintenance", "released"], "description": "development=開発中 / maintenance=リリース後保守フェーズ / released=デプロイ完了・保守移行済み" }
      }
    },
    "kpi": {
      "type": "object",
      "properties": {
        "success_rate_target": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "execution": {
      "type": "object",
      "required": ["max_duration_minutes", "phase"],
      "properties": {
        "start_time": { "type": ["string", "null"], "format": "date-time" },
        "project_start_date": { "type": ["string", "null"], "format": "date", "description": "Project registration date (YYYY-MM-DD). Release deadline = +6 months." },
        "release_deadline": { "type": ["string", "null"], "format": "date", "description": "Production release deadline (YYYY-MM-DD). Strictly enforced." },
        "project_period_months": { "type": ["integer", "null"], "minimum": 1, "description": "Project duration in months (default 6)." },
        "max_duration_minutes": { "type": "integer", "minimum": 1, "maximum": 300 },
        "elapsed_minutes": { "type": "number", "minimum": 0 },
        "remaining_minutes": { "type": "number", "minimum": 0 },
        "phase": {
          "type": "string",
          "enum": ["Idle", "Monitor", "Development", "Verify", "Improvement", "Repair", "Release", "Maintenance", "Triage"]
        },
        "auto_stop_threshold": { "type": "integer", "minimum": 1 },
        "graceful_shutdown": { "type": "boolean" },
        "last_session_summary": { "type": "string" },
        "last_stop_at": { "type": ["string", "null"], "format": "date-time" },
        "current_session_start_at": { "type": ["string", "null"], "format": "date-time" },
        "current_session_prs": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        },
        "current_session_last_pr": { "type": ["integer", "null"] },
        "current_session_last_merge_commit": { "type": ["string", "null"] },
        "current_session_last_merged_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "session": {
      "type": "object",
      "properties": {
        "context_load_tier": {
          "type": "string",
          "enum": ["minimal", "standard", "full"]
        }
      }
    },
    "stable": {
      "type": "object",
      "required": ["consecutive_success", "target_n", "stable_achieved"],
      "properties": {
        "consecutive_success": { "type": "integer", "minimum": 0 },
        "target_n": { "type": "integer", "enum": [2, 3, 5] },
        "target_n_reason": { "type": "string" },
        "last_verified_at": { "type": ["string", "null"], "format": "date-time" },
        "stable_achieved": { "type": "boolean" },
        "stable_achieved_pr": { "type": ["integer", "null"] },
        "stable_achieved_issue": { "type": ["integer", "null"] }
      }
    },
    "automation": {
      "type": "object",
      "properties": {
        "auto_issue_generation": { "type": "boolean" },
        "self_evolution": { "type": "boolean" }
      }
    },
    "operation_mode": {
      "type": "object",
      "description": "ClaudeOS v8.3+ three-tier operation mode. See CLAUDE.md §3 / .claude/claudeos/system/conducted-mode.md.",
      "properties": {
        "current": {
          "type": "string",
          "enum": ["cron_autonomous", "manual_subagent", "conducted"],
          "description": "cron_autonomous=Linux cron unattended SubAgent / manual_subagent=interactive SubAgent / conducted=official Agent Teams + Agent View"
        },
        "conducted": {
          "type": "object",
          "description": "Conducted mode (official Agent Teams + Agent View) configuration. Active only when current='conducted'.",
          "properties": {
            "enabled": { "type": "boolean" },
            "lead_session_started_at": { "type": ["string", "null"], "format": "date-time" },
            "max_session_minutes": { "type": "integer", "minimum": 1, "maximum": 300, "description": "Recommended ≤ 240 to ensure graceful shutdown completes before 5h hard limit" },
            "graceful_shutdown_threshold_minutes": { "type": "integer", "minimum": 5, "description": "Minutes before max_session to start graceful shutdown" },
            "spawn_token_threshold_pct": { "type": "integer", "minimum": 0, "maximum": 100, "description": "If token usage exceeds this %, no new teammate spawn allowed" },
            "spawn_freeze_remaining_minutes": { "type": "integer", "minimum": 0, "description": "If remaining session minutes below this, no new teammate spawn allowed" }
          }
        }
      }
    },
    "agent_teams": {
      "type": "object",
      "description": "Mirror of conducted-mode teammate state. Written by session-end.js (Stop hook) and lead CTO during phase transitions. Used to restore spawn plan on next session (teammates themselves cannot be resumed per official constraint).",
      "properties": {
        "last_snapshot_at": { "type": ["string", "null"], "format": "date-time" },
        "active_team_id": { "type": ["string", "null"] },
        "teammates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "status"],
            "properties": {
              "role": {
                "type": "string",
                "enum": [
                  "CTO", "ProductManager", "Architect", "Developer", "Reviewer",
                  "Debugger", "QA", "Security", "DevOps", "Analyst",
                  "EvolutionManager", "ReleaseManager",
                  "e2e-runner", "security-reviewer", "PerformanceReviewer"
                ]
              },
              "status": {
                "type": "string",
                "enum": ["working", "needs_input", "completed", "failed", "stopped"]
              },
              "worktree": { "type": ["string", "null"] },
              "last_commit": { "type": ["string", "null"] },
              "last_message_at": { "type": ["string", "null"], "format": "date-time" },
              "assigned_issue": { "type": ["integer", "null"], "minimum": 1 },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "codex": {
      "type": "object",
      "properties": {
        "setup_checked": { "type": "boolean" },
        "setup_checked_at": { "type": ["string", "null"], "format": "date-time" },
        "review_gate": { "type": "string", "enum": ["on", "off"] },
        "last_review_status": { "type": "string", "enum": ["none", "running", "done", "failed"] },
        "last_review_type": { "type": "string" },
        "last_review_job_id": { "type": "string" },
        "last_review_summary": { "type": "string" },
        "last_adversarial_status": { "type": "string", "enum": ["none", "running", "done", "failed"] },
        "last_adversarial_job_id": { "type": "string" },
        "last_adversarial_summary": { "type": "string" },
        "last_rescue_status": { "type": "string", "enum": ["none", "running", "done", "failed"] },
        "last_rescue_job_id": { "type": "string" },
        "last_rescue_summary": { "type": "string" },
        "blocking_issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severity": { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] }
      }
    },
    "token": {
      "type": "object",
      "required": ["total_budget", "used", "remaining", "allocation"],
      "properties": {
        "total_budget": { "type": "integer", "const": 100 },
        "used": { "type": "number", "minimum": 0, "maximum": 100 },
        "remaining": { "type": "number", "minimum": 0, "maximum": 100 },
        "tokenizer_calibration": { "type": "string", "enum": ["opus-4-7", "opus-4-6", "sonnet-4-6"] },
        "calibration_factor": { "type": "number", "minimum": 1.0 },
        "allocation": {
          "type": "object",
          "required": ["monitor", "development", "verify", "improvement", "debug", "release"],
          "properties": {
            "monitor": { "type": "integer", "minimum": 0 },
            "development": { "type": "integer", "minimum": 0 },
            "verify": { "type": "integer", "minimum": 0 },
            "improvement": { "type": "integer", "minimum": 0 },
            "debug": { "type": "integer", "minimum": 0 },
            "release": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "task_budget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "minimum": { "type": "integer", "minimum": 0 },
        "beta_header": { "type": "string" },
        "applied_phases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skipped_phases": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "compact": {
      "type": "object",
      "required": ["trigger_at_pct"],
      "properties": {
        "trigger_at_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "verify_failure_threshold": { "type": "integer", "minimum": 1 },
        "phase_transition": { "type": "boolean" },
        "rescue_pre_trigger": { "type": "boolean" },
        "long_session_minutes": { "type": "integer", "minimum": 1 },
        "last_pre_compact_at": { "type": ["string", "null"], "format": "date-time" },
        "snapshot_dir": { "type": "string" }
      }
    },
    "notification": {
      "type": "object",
      "properties": {
        "stable": { "type": "boolean" },
        "blocked": { "type": "boolean" },
        "five_hour_end": { "type": "boolean" },
        "critical_review": { "type": "boolean" },
        "channel": { "type": "string", "enum": ["push", "email", "webhook"] },
        "last_sent_event": { "type": ["string", "null"] },
        "last_sent_at": { "type": ["string", "null"], "format": "date-time" },
        "last_dispatched_stable_notification": {
          "type": ["object", "null"],
          "description": "Record of the last STABLE notification dispatched by notify-stable.js (via session-end.js require).",
          "properties": {
            "pr": { "type": ["integer", "null"] },
            "commit": { "type": ["string", "null"] },
            "scope": { "type": "string" },
            "target_n": { "type": "integer" },
            "consecutive_success": { "type": "integer" },
            "dispatched_via": { "type": "string" },
            "dispatched_at": { "type": ["string", "null"], "format": "date-time" }
          }
        }
      }
    },
    "effort_strategy": {
      "type": "object",
      "required": ["default", "current"],
      "properties": {
        "default": { "type": "string", "enum": ["xhigh", "high", "medium", "low"] },
        "current": { "type": "string", "enum": ["xhigh", "high", "medium", "low"] },
        "concurrent_worktrees_threshold": { "type": "integer", "minimum": 1 },
        "low_token_threshold_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "force_medium_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "doc_only_effort": { "type": "string", "enum": ["xhigh", "high", "medium", "low"] },
        "critical_change_keep_xhigh": { "type": "boolean" }
      }
    },
    "cache": {
      "type": "object",
      "properties": {
        "prompt_caching_1h_enabled": { "type": "boolean" },
        "applied_blocks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "frontier": {
      "type": "object",
      "properties": {
        "last_test_date": { "type": ["string", "null"], "format": "date-time" },
        "test_count": { "type": "integer", "minimum": 0 },
        "last_deprecation_candidates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "last_low_usage_items": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "message_bus": {
      "type": "object",
      "properties": {
        "phase": {
          "type": "object",
          "properties": {
            "transition": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "ci": {
          "type": "object",
          "properties": {
            "status": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "learning": {
      "type": "object",
      "properties": {
        "usage_history": {
          "type": "object",
          "properties": {
            "agents": { "type": "object" },
            "skills": { "type": "object" },
            "commands": { "type": "object" },
            "hooks": { "type": "object" }
          }
        },
        "dead_weight": {
          "type": "object",
          "properties": {
            "stale_threshold_days": { "type": "integer", "minimum": 1 },
            "grace_period_days": { "type": "integer", "minimum": 0 },
            "last_detection_run": { "type": ["string", "null"], "format": "date-time" },
            "candidates_pending_issue": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "debug": {
      "type": "object",
      "properties": {
        "last_failure_category": { "type": ["string", "null"] },
        "failure_count_by_category": { "type": "object" },
        "same_error_retry_count": { "type": "integer", "minimum": 0 },
        "rescue_retry_count": { "type": "integer", "minimum": 0 },
        "last_root_cause": { "type": ["string", "null"] },
        "last_fix_scope": { "type": ["string", "null"] },
        "last_fix_strategy": { "type": ["string", "null"] },
        "flaky_suspected": { "type": "boolean" },
        "debug_mode": { "type": ["string", "boolean"] }
      }
    },
    "onboarding": {
      "type": "object",
      "properties": {
        "last_refresh": { "type": ["string", "null"], "format": "date-time" },
        "refresh_count": { "type": "integer", "minimum": 0 }
      }
    },
    "improvement": {
      "type": "object",
      "properties": {
        "stop_doing_review_date": { "type": ["string", "null"], "format": "date" },
        "stop_doing_review_interval_days": { "type": "integer", "minimum": 1 },
        "stop_doing_last_run": { "type": ["string", "null"], "format": "date-time" },
        "stop_doing_candidates_found": { "type": "integer", "minimum": 0 }
      }
    },
    "maintenance": {
      "type": "object",
      "description": "Post-release maintenance phase configuration. Activated when project.phase_mode = 'maintenance'.",
      "properties": {
        "phase_mode": { "type": "string", "enum": ["development", "maintenance"] },
        "released_at": { "type": ["string", "null"], "format": "date-time" },
        "sla_target_availability": { "type": "number", "minimum": 0, "maximum": 1, "description": "SLA availability target (e.g. 0.995 = 99.5%)" },
        "mttr_target_hours": { "type": "number", "minimum": 0, "description": "Mean Time To Recovery target in hours" },
        "session_max_minutes": { "type": "integer", "minimum": 1, "maximum": 300, "description": "Max session length in maintenance mode (default 120)" },
        "cron_schedule": { "type": "string", "enum": ["daily", "weekly", "biweekly", "monthly"], "description": "Maintenance session frequency" },
        "error_budget_remaining_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "last_dependency_scan": { "type": ["string", "null"], "format": "date-time" },
        "last_security_audit": { "type": ["string", "null"], "format": "date-time" },
        "last_weekly_devops": { "type": ["string", "null"], "format": "date-time" },
        "last_monthly_devops": { "type": ["string", "null"], "format": "date-time" },
        "last_quarterly_review": { "type": ["string", "null"], "format": "date-time" },
        "incident_count_30d": { "type": "integer", "minimum": 0 },
        "open_incidents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Active incident IDs (e.g. ['incident-20261022-P1'])"
        },
        "last_incident_id": { "type": ["string", "null"] }
      }
    },
    "deploy": {
      "type": "object",
      "description": "Deployment tracking. CTO sets ready=true when system is deploy-ready. Actual deploy is executed manually by the user.",
      "properties": {
        "ready": { "type": "boolean", "description": "CTO sets true when deployment is approved" },
        "runbook_generated": { "type": "boolean" },
        "runbook_path": { "type": ["string", "null"], "description": "Path to generated deploy runbook (e.g. reports/deploy-runbook-YYYYMMDD.md)" },
        "pre_deploy_checklist_done": { "type": "boolean" },
        "executed_at": { "type": ["string", "null"], "format": "date-time", "description": "Timestamp of manual deploy execution by user" },
        "executed_by": { "type": ["string", "null"] },
        "environment": { "type": ["string", "null"], "enum": ["staging", "production", null] },
        "post_deploy_verified": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    }
  }
}
