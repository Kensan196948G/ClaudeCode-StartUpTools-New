{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/claudeos/scripts/hooks/usage-tracker.js"
          }
        ]
      },
      {
        "matcher": "TeamCreate",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/claudeos/scripts/hooks/agent-teams-tracker.js"
          }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/claudeos/scripts/hooks/agent-teams-tracker.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/claudeos/scripts/hooks/pre-compact.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/claudeos/scripts/hooks/session-start.js"
          },
          {
            "type": "command",
            "command": "node .claude/claudeos/scripts/hooks/verify-goal-set.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/claudeos/scripts/hooks/session-end.js"
          }
        ]
      }
    ]
  }
}
